# Shared environment variables
# Copy to .env and fill in values. Never commit secrets.
# Full reference: docs/ENVIRONMENT.md

# Application
NODE_ENV=development
APP_NAME=Graphology Platform
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001

# Database (Neon PostgreSQL in production; Docker locally)
DATABASE_URL=postgresql://graphology:graphology@localhost:5432/graphology?schema=public
DIRECT_URL=postgresql://graphology:graphology@localhost:5432/graphology?schema=public

# Database seed (development only)
SEED_ADMIN_EMAIL=admin@graphology.local
SEED_ADMIN_PASSWORD=change-me-in-development
SEED_ADMIN_FIRST_NAME=System
SEED_ADMIN_LAST_NAME=Administrator
SEED_TEACHER_EMAIL=teacher@graphology.local
SEED_TEACHER_PASSWORD=change-me-in-development
SEED_TEACHER_FIRST_NAME=Sample
SEED_TEACHER_LAST_NAME=Teacher
SEED_STUDENT_EMAIL=student@graphology.local
SEED_STUDENT_PASSWORD=change-me-in-development
SEED_STUDENT_FIRST_NAME=Sample
SEED_STUDENT_LAST_NAME=Student

# JWT access tokens
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_ACCESS_EXPIRATION=15m

# Refresh tokens (REFRESH_TOKEN_* preferred; JWT_REFRESH_* accepted as aliases)
REFRESH_TOKEN_SECRET=change-me-in-production
REFRESH_TOKEN_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-in-production
JWT_REFRESH_EXPIRATION=7d

# Google OAuth (optional until OAuth task)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Razorpay (optional locally; required to create provider orders)
RAZORPAY_KEY_ID=
RAZORPAY_SECRET=
# RAZORPAY_KEY_SECRET is accepted as a legacy alias for RAZORPAY_SECRET.
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_API_URL=https://api.razorpay.com/v1

# Email via Resend (EMAIL_FROM preferred; RESEND_FROM_EMAIL accepted as alias)
# RESEND_API_KEY and RESEND_WEBHOOK_SECRET are optional locally (sandbox mode
# captures emails without network calls) and REQUIRED in production.
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
EMAIL_FROM=no-reply@graphology.local
RESEND_FROM_EMAIL=
EMAIL_REPLY_TO=

# Email provider selection: RESEND | SANDBOX
EMAIL_PROVIDER=RESEND
# Sandbox mode defaults to true outside production and is FORBIDDEN in production.
EMAIL_SANDBOX_MODE=true

# Email queue tuning
EMAIL_QUEUE_POLL_INTERVAL_MS=15000
EMAIL_QUEUE_BATCH_SIZE=20
EMAIL_MAX_ATTEMPTS=5
# Max accepted webhook timestamp age in seconds (replay protection)
EMAIL_WEBHOOK_TOLERANCE_SECONDS=300

# Cloudinary (optional until media uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
