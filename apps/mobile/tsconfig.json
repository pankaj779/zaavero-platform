{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@graphology/types": ["../../packages/types/src/index.ts"],
      "@graphology/utils": ["../../packages/utils/src/index.ts"],
      "@graphology/auth": ["../../packages/auth/src/index.ts"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": ["node_modules", "dist", "**/__tests__/**", "**/*.test.ts", "vitest.config.ts", "vitest.setup.ts"]
}
