{
  "expo": {
    "name": "Graphology",
    "slug": "graphology-platform",
    "owner": "graphology",
    "scheme": "graphology",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "jsEngine": "hermes",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1120"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.graphology.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Graphology uses the camera to capture avatars and upload assignment documents.",
        "NSPhotoLibraryUsageDescription": "Graphology accesses your photos to upload avatars and assignment files.",
        "NSFaceIDUsageDescription": "Graphology uses Face ID to unlock your account securely.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": ["graphology"]
          }
        ]
      },
      "associatedDomains": ["applinks:app.graphology.example", "applinks:www.graphology.example"]
    },
    "android": {
      "package": "app.graphology.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B1120"
      },
      "permissions": [
        "CAMERA",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "app.graphology.example",
              "pathPrefix": "/"
            },
            {
              "scheme": "graphology"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "Graphology uses the camera to capture avatars and upload assignment documents."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Graphology accesses your photos to upload avatars and assignment files."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#4F46E5"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://api.example.com/api/v1",
      "eas": {
        "projectId": "00000000-0000-0000-0000-000000000000"
      },
      "router": {
        "origin": false
      }
    },
    "updates": {
      "url": "https://u.expo.dev/00000000-0000-0000-0000-000000000000",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
