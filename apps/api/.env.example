# Backend environment variables
# Prefer the monorepo root .env. See docs/ENVIRONMENT.md.

NODE_ENV=development
PORT=3001
HOST=0.0.0.0
APP_NAME=Graphology Platform
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=postgresql://graphology:graphology@localhost:5432/graphology?schema=public
DIRECT_URL=postgresql://graphology:graphology@localhost:5432/graphology?schema=public

# JWT access tokens
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_ACCESS_EXPIRATION=15m

# Refresh tokens
REFRESH_TOKEN_SECRET=change-me-in-production
REFRESH_TOKEN_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-in-production
JWT_REFRESH_EXPIRATION=7d

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Razorpay (placeholders until payments)
RAZORPAY_KEY_ID=rzp_placeholder
RAZORPAY_SECRET=rzp_secret_placeholder
RAZORPAY_KEY_SECRET=rzp_secret_placeholder

# Email (Resend)
RESEND_API_KEY=re_placeholder
EMAIL_FROM=noreply@example.com
RESEND_FROM_EMAIL=noreply@example.com

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
