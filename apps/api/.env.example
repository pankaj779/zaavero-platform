# Backend environment variables
# Prefer the monorepo root .env. See docs/ENVIRONMENT.md.

NODE_ENV=development
PORT=3001
HOST=0.0.0.0
APP_NAME=Graphology Platform
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=postgresql://graphology:graphology@localhost:5432/graphology?schema=public
DIRECT_URL=postgresql://graphology:graphology@localhost:5432/graphology?schema=public

# JWT access tokens
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_ACCESS_EXPIRATION=15m

# Refresh tokens
REFRESH_TOKEN_SECRET=change-me-in-production
REFRESH_TOKEN_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-in-production
JWT_REFRESH_EXPIRATION=7d

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Razorpay (placeholders until payments)
RAZORPAY_KEY_ID=rzp_placeholder
RAZORPAY_SECRET=rzp_secret_placeholder
RAZORPAY_KEY_SECRET=rzp_secret_placeholder

# Email (Resend)
# RESEND_API_KEY and RESEND_WEBHOOK_SECRET are optional locally (sandbox mode
# captures emails without network calls) and REQUIRED in production.
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
EMAIL_FROM=no-reply@graphology.local
# Legacy alias for EMAIL_FROM (still supported)
RESEND_FROM_EMAIL=
EMAIL_REPLY_TO=

# Email provider selection: RESEND | SANDBOX
EMAIL_PROVIDER=RESEND
# Sandbox mode defaults to true outside production and is FORBIDDEN in production.
EMAIL_SANDBOX_MODE=true

# Email queue tuning
EMAIL_QUEUE_POLL_INTERVAL_MS=15000
EMAIL_QUEUE_BATCH_SIZE=20
EMAIL_MAX_ATTEMPTS=5
# Max accepted webhook timestamp age (replay protection)
EMAIL_WEBHOOK_TOLERANCE_SECONDS=300

# Storage (Cloudinary)
# Credentials are optional locally (sandbox mode captures assets without
# network calls) and REQUIRED in production when STORAGE_PROVIDER=CLOUDINARY.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER_ROOT=graphology

# Storage provider selection: CLOUDINARY | SANDBOX
STORAGE_PROVIDER=CLOUDINARY
# Sandbox mode defaults to true outside production and is FORBIDDEN in production.
STORAGE_SANDBOX_MODE=true

# Storage tuning
STORAGE_SIGNED_UPLOAD_TTL_SECONDS=600
STORAGE_MAX_FILE_SIZE_BYTES=104857600
STORAGE_SERVER_UPLOAD_MAX_BYTES=10485760
# Comma-separated MIME allow list (omit to use built-in defaults)
# STORAGE_ALLOWED_MIME_TYPES=image/jpeg,image/png,application/pdf

# Meetings (Zoom / Google Meet / Sandbox)
# TOKEN_ENCRYPTION_KEY is required in production (64-char hex, 32-byte base64, or passphrase).
TOKEN_ENCRYPTION_KEY=dev-only-meeting-token-encryption-key
# Sandbox mode defaults to true outside production and is FORBIDDEN in production.
MEETING_SANDBOX_MODE=true
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET=
# Optional overrides; falls back to GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET.
GOOGLE_MEET_CLIENT_ID=
GOOGLE_MEET_CLIENT_SECRET=

# AI Platform (Phase 16)
AI_PROVIDER=OPENAI
# AI_EMBEDDING_PROVIDER=OPENAI
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENROUTER_API_KEY=
GROQ_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434
AI_TIMEOUT_MS=60000
AI_MAX_RETRIES=2
AI_DAILY_TOKEN_LIMIT_USER=200000
AI_MONTHLY_TOKEN_LIMIT_USER=2000000
AI_DAILY_TOKEN_LIMIT_ORG=2000000
AI_MONTHLY_TOKEN_LIMIT_ORG=20000000
AI_CHUNK_SIZE=800
AI_CHUNK_OVERLAP=120
AI_RETRIEVAL_TOP_K=6
AI_QUEUE_POLL_INTERVAL_MS=15000

