# Database package environment
#
# Prisma commands load the monorepo root .env automatically via dotenv-cli.
# Keep your real values in the repository root .env file:
#
#   ../../.env
#
# Required variables:
#   DATABASE_URL
#   DIRECT_URL
#   SEED_ADMIN_EMAIL
#   SEED_ADMIN_PASSWORD
#
# Optional LMS seed users (defaults used when omitted):
#   SEED_TEACHER_EMAIL / SEED_TEACHER_PASSWORD
#   SEED_STUDENT_EMAIL / SEED_STUDENT_PASSWORD
