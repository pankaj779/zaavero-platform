{
  "name": "graphology-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,css}\"",
    "clean": "turbo run clean",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @graphology/database db:generate",
    "db:migrate": "pnpm --filter @graphology/database db:migrate",
    "db:migrate:deploy": "pnpm --filter @graphology/database db:migrate:deploy",
    "db:seed": "pnpm --filter @graphology/database db:seed",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4"
  }
}
